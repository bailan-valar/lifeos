# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lifeos"

# JWT Secret (generate a secure random string)
JWT_SECRET="your-secret-key-here"

# API Configuration
NUXT_PUBLIC_API_BASE="/api"

# CouchDB Sync (optional, used as default remote for new/empty workspaces)
NUXT_PUBLIC_COUCHDB_URL=""
NUXT_PUBLIC_COUCHDB_USERNAME=""
NUXT_PUBLIC_COUCHDB_PASSWORD=""
NUXT_PUBLIC_COUCHDB_PREFIX="lifeos-"

# Anthropic API (for learning goal AI split feature)
# Leave empty to use preset templates only
ANTHROPIC_API_KEY=""

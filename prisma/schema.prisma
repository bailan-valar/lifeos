// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scenes     Scene[]
  sessions   Session[]
  folders    Folder[]
  notes      Note[]
  workspaces Workspace[]
}

model Workspace {
  id             String   @id @default(cuid())
  userId         String
  name           String
  remoteUrl      String?
  remotePrefix   String   @default("lifeos-")
  remoteUsername String?
  remotePassword String?
  localId        String   @unique @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Scene {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  icon        String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
  groups      Group[]

  @@index([userId])
}

model Group {
  id        String    @id @default(cuid())
  sceneId   String
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@index([sceneId])
}

model Project {
  id          String   @id @default(cuid())
  sceneId     String
  groupId     String?
  title       String
  content     String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scene       Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([sceneId])
  @@index([groupId])
}

// Block Note System Models

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[] @relation("FolderHierarchy")
  notes     Note[]

  @@index([userId])
  @@index([parentId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("")
  folderId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  blocks    Block[]
  tags      NoteTag[]

  @@index([userId])
  @@index([folderId])
  @@index([createdAt])
}

model Block {
  id        String   @id @default(cuid())
  noteId    String
  type      String   @default("text")
  content   String   @default("")
  order     Int      @default(0)
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  links     BlockLink[] @relation("SourceLinks")
  backlinks BlockLink[] @relation("TargetLinks")

  @@index([noteId])
  @@index([noteId, order])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?  @default("#3B82F6")
  createdAt DateTime @default(now())

  notes     NoteTag[]

  @@index([name])
}

model NoteTag {
  id        String   @id @default(cuid())
  noteId    String
  tagId     String
  createdAt DateTime @default(now())

  note      Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag       Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([noteId, tagId])
  @@index([noteId])
  @@index([tagId])
}

model BlockLink {
  id             String   @id @default(cuid())
  sourceBlockId  String
  targetBlockId  String
  createdAt      DateTime @default(now())

  sourceBlock    Block    @relation("SourceLinks", fields: [sourceBlockId], references: [id], onDelete: Cascade)
  targetBlock    Block    @relation("TargetLinks", fields: [targetBlockId], references: [id], onDelete: Cascade)

  @@unique([sourceBlockId, targetBlockId])
  @@index([sourceBlockId])
  @@index([targetBlockId])
}

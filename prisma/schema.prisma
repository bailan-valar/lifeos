// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scenes    Scene[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Scene {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  icon        String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
  groups      Group[]

  @@index([userId])
}

model Group {
  id        String    @id @default(cuid())
  sceneId   String
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@index([sceneId])
}

model Project {
  id          String   @id @default(cuid())
  sceneId     String
  groupId     String?
  title       String
  content     String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scene       Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([sceneId])
  @@index([groupId])
}
